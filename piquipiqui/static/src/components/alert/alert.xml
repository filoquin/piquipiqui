<t t-name="Alert">
    <div class="piquipiqui-alerts">
        <t t-foreach="state.alerts" t-as="alert" t-key="alert.id">
            <div t-attf-class="piquipiqui-alert piquipiqui-alert--{{alert.type}}"
                 t-on-click="() => this.dismiss(alert.id)">
                <span t-esc="alert.message"/>
            </div>
        </t>
    </div>
</t>
