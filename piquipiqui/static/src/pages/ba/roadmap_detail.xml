<t t-name="RoadmapDetail">
    <div class="page">
        <div class="page-header">
            <button class="btn-back" t-on-click="back">←</button>
            <h1 t-esc="state.roadmap ? state.roadmap.number : '...'"/>
            <button class="btn-icon" t-on-click="showMap" title="Mapa">🗺️</button>
        </div>
        <div class="page-body">
            <t t-if="state.loading">
                <div class="loading"><div class="spinner"/><span>Cargando...</span></div>
            </t>
            <t t-else="">

                <!-- Datos del roadmap -->
                <t t-if="state.roadmap">
                    <div class="picking-card" style="pointer-events:none">
                        <t t-if="state.roadmap.preparation_date">
                            <div class="picking-card__date" t-esc="formatDate(state.roadmap.preparation_date)"/>
                        </t>
                        <t t-if="state.roadmap.driver_user_id">
                            <div class="picking-card__row">
                                <span class="picking-card__label">Conductor</span>
                                <span t-esc="state.roadmap.driver_user_id[1]"/>
                            </div>
                        </t>
                        <t t-if="state.roadmap.vehicle_id">
                            <div class="picking-card__row">
                                <span class="picking-card__label">Vehículo</span>
                                <span t-esc="state.roadmap.vehicle_id[1]"/>
                            </div>
                        </t>
                        <div class="picking-card__row">
                            <span class="picking-card__label">Remitos</span>
                            <span t-esc="state.roadmap.picking_ids.length"/>
                        </div>
                    </div>
                </t>

                <!-- Lista de pickings -->
                <t t-if="state.pickings.length === 0">
                    <div class="empty">Sin remitos</div>
                </t>
                <t t-else="">
                    <t t-foreach="state.pickings" t-as="pk" t-key="pk.id">
                        <div class="picking-card picking-card--clickable" t-on-click="() => this.openPicking(pk)">
                            <div class="picking-card__header">
                                <span class="picking-card__name" t-esc="pk.display_name"/>
                                <span t-attf-class="badge badge--{{pk.state}}" t-esc="stateLabel(pk.state)"/>
                            </div>
                            <t t-if="pk.partner_id">
                                <div class="picking-card__row">
                                    <span class="picking-card__label">Cliente</span>
                                    <span t-esc="pk.partner_id[1]"/>
                                </div>
                            </t>
                            <t t-if="pk._partner.street or pk._partner.city">
                                <div class="picking-card__address" t-esc="formatAddress(pk._partner)"/>
                            </t>
                            <t t-if="pk.origin">
                                <div class="picking-card__row">
                                    <span class="picking-card__label">Origen</span>
                                    <span t-esc="pk.origin"/>
                                </div>
                            </t>
                            <t t-if="pk._partner.phone or pk._partner.mobile">
                                <div class="picking-card__row">
                                    <span class="picking-card__label">Teléfono</span>
                                    <span t-esc="formatPhone(pk._partner)"/>
                                </div>
                            </t>

                            <!-- Acciones -->
                            <div class="card-actions">
                                <button class="card-action-btn" t-on-click.stop="() => this.geolocate(pk)" title="Geoposicionar">
                                    <i class="fa-solid fa-location-dot"/>
                                </button>
                                <button class="card-action-btn card-action-btn--whatsapp"
                                        t-on-click.stop="() => this.whatsapp(pk)"
                                        t-att-disabled="!(pk._partner.phone or pk._partner.mobile)"
                                        title="WhatsApp">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                                    </svg>
                                </button>
                                <button class="card-action-btn"
                                        t-on-click.stop="() => this.call(pk)"
                                        t-att-disabled="!(pk._partner.phone or pk._partner.mobile)"
                                        title="Llamar">
                                    <i class="fa-solid fa-phone"/>
                                </button>
                                <button class="card-action-btn"
                                        t-on-click.stop="() => this.moveUp(pk_index)"
                                        t-att-disabled="pk_index === 0"
                                        title="Subir">
                                    <i class="fa-solid fa-arrow-up"/>
                                </button>
                                <button class="card-action-btn"
                                        t-on-click.stop="() => this.moveDown(pk_index)"
                                        t-att-disabled="pk_index === state.pickings.length - 1"
                                        title="Bajar">
                                    <i class="fa-solid fa-arrow-down"/>
                                </button>
                            </div>
                        </div>
                    </t>
                </t>
            </t>
        </div>
    </div>
</t>
