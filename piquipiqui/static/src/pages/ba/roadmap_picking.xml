<t t-name="RoadmapPicking">
    <div class="page">
        <div class="page-header">
            <button class="btn-back" t-on-click="back">←</button>
            <h1 t-esc="state.picking ? state.picking.display_name : '...'"/>
            <div class="header-actions">
                <button class="btn-icon" t-att-class="state.showDone ? 'btn-icon btn-icon--active' : 'btn-icon'"
                        t-on-click="toggleShowDone" title="Ver entregados">
                    <i class="fa-solid fa-eye"/>
                </button>
                <button class="btn-icon" t-on-click="refresh"><i class="fa-solid fa-rotate-right"/></button>
            </div>
        </div>

        <div class="page-body">
            <t t-if="state.loading">
                <div class="loading"><div class="spinner"/><span>Cargando...</span></div>
            </t>
            <t t-else="">

                <!-- Cabecera del picking -->
                <t t-if="state.picking">
                    <div class="picking-card" style="pointer-events:none">
                        <t t-if="state.picking.partner_id">
                            <div class="picking-card__row">
                                <span class="picking-card__label">Cliente</span>
                                <span t-esc="state.picking.partner_id[1]"/>
                            </div>
                        </t>
                        <t t-if="state.picking.origin">
                            <div class="picking-card__row">
                                <span class="picking-card__label">Origen</span>
                                <span t-esc="state.picking.origin"/>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Líneas -->
                <t t-if="visibleMoves.length === 0">
                    <div class="empty">Sin líneas pendientes</div>
                </t>
                <t t-else="">
                    <t t-foreach="visibleMoves" t-as="move" t-key="move.id">
                        <div t-att-class="move.quantity_done >= move.product_uom_qty ? 'move-item move-item--done' : 'move-item'">
                            <div class="move-item__qty" t-on-click="() => this.openModal(move.id)">
                                <div t-att-class="move.quantity_done >= move.product_uom_qty ? 'qty-badge qty-badge--ok' :
                                                  move.quantity_done > 0                    ? 'qty-badge qty-badge--pending' :
                                                                                              'qty-badge qty-badge--pending'">
                                    <span t-esc="move.quantity_done"/>
                                    <small>Scan</small>
                                </div>
                                <div class="qty-res">
                                    <span t-esc="move.product_uom_qty"/>
                                    <small>Dem</small>
                                </div>
                            </div>
                            <div class="move-item__info">
                                <div class="move-item__product" t-esc="move.product_id[1]"/>
                                <div class="move-item__meta" t-esc="move.product_uom[1]"/>
                            </div>
                            <button class="btn-icon btn-icon--dark" t-on-click="() => this.openModal(move.id)">
                                <i class="fa-solid fa-list"/>
                            </button>
                        </div>
                    </t>
                </t>

                <!-- Botón validar -->
                <t t-if="state.moves.length > 0 and state.picking and state.picking.state !== 'done'">
                    <div style="padding: 16px 0;">
                        <button class="btn btn--primary w-full"
                                t-on-click="validate"
                                t-att-disabled="state.saving">
                            <t t-if="state.saving">Guardando...</t>
                            <t t-else="">Validar remito</t>
                        </button>
                    </div>
                </t>
            </t>
        </div>
    </div>

    <!-- Modal de línea -->
    <t t-if="activeMove">
        <div class="modal-overlay" t-on-click.self="closeModal">
            <div class="modal-box">
                <div class="modal-header">
                    <h2 t-esc="activeMove.product_id[1]"/>
                </div>
                <div class="modal-body">
                    <div t-att-class="activeMove.scanned_qty > 0 ? 'qty-display qty-display--active' : 'qty-display'">
                        <span t-esc="activeMove.scanned_qty"/>
                        <small>Escaneados</small>
                    </div>
                    <table class="detail-table">
                        <tr>
                            <td>Unidad</td>
                            <td><strong t-esc="activeMove.product_uom[1]"/></td>
                        </tr>
                        <tr>
                            <td>Hecho / Demanda</td>
                            <td>
                                <strong t-esc="activeMove.quantity_done"/> /
                                <strong t-esc="activeMove.product_uom_qty"/>
                            </td>
                        </tr>
                        <t t-if="activeMove.barcode">
                            <tr><td>Código de barras</td><td><strong t-esc="activeMove.barcode"/></td></tr>
                        </t>
                        <t t-if="activeMove.default_code">
                            <tr><td>Código interno</td><td><strong t-esc="activeMove.default_code"/></td></tr>
                        </t>
                    </table>
                    <div class="qty-dir-toggle">
                        <button t-on-click="() => state.qtyDir = -1"
                                t-att-class="state.qtyDir === -1 ? 'active' : ''">−</button>
                        <button t-on-click="() => state.qtyDir = 1"
                                t-att-class="state.qtyDir === 1 ? 'active' : ''">+</button>
                    </div>
                    <div class="qty-buttons">
                        <t t-foreach="[1, 5, 10, 50, 100]" t-as="n" t-key="n">
                            <button class="qty-btn"
                                    t-on-click="() => this._addQty(state.activeId, n * state.qtyDir)"
                                    t-esc="n"/>
                        </t>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn--secondary" t-on-click="closeModal">Cerrar</button>
                </div>
            </div>
        </div>
    </t>
</t>
